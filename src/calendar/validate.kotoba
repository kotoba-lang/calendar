(ns calendar.validate
  (:require [calendar.model :as model])
  (:export [event-valid? valid?]))

(def event-type
  [:record :calendar/event [[:id :keyword] [:start :i64] [:end :i64]]])
(def events-type [:map :keyword [:alias event-type]])
(def calendar-type
  [:record :calendar/calendar [[:id :keyword] [:events [:alias events-type]]]])
(def entry-type [:vector [:keyword [:alias event-type]]])
(def entry-option-type [:option [:alias entry-type]])

(defn event-valid? [event [:alias event-type]] :bool
  (if (< (record-get event-type event :start)
         (record-get event-type event :end)) true false))

(defn valid-events-loop
  [events [:alias events-type] index :i64] :bool
  (if (= index (typed-map-count events-type events)) true
    (match-option
      (typed-map-entry-at events-type events index) entry-option-type
      (none false)
      (some entry
        (if (event-valid? (hetero-vector-at entry-type entry 1))
          (valid-events-loop events (+ index 1))
          false)))))

(defn valid? [calendar [:alias calendar-type]] :bool
  (let [events (record-get calendar-type calendar :events)
        count (typed-map-count events-type events)]
    (if (< 8 count) false
      (valid-events-loop events 0))))
