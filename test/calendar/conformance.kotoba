(ns calendar.conformance
  (:require [calendar.model :as model]
            [calendar.validate :as validate])
  (:export [main]))

(def event-type
  [:record :calendar/event [[:id :keyword] [:start :i64] [:end :i64]]])
(def event-option-type [:option [:alias event-type]])

(defn main [] :i64
  (let [briefing (model/new-event :weekly-briefing 100 130)
        review (model/new-event :review 120 150)
        invalid (model/new-event :invalid 200 200)
        calendar (model/add-event
                   (model/add-event (model/new-calendar :gftd-calendar) briefing)
                   review)
        c1 (model/add-event (model/new-calendar :limit) (model/new-event :e1 1 2))
        c2 (model/add-event c1 (model/new-event :e2 2 3))
        c3 (model/add-event c2 (model/new-event :e3 3 4))
        c4 (model/add-event c3 (model/new-event :e4 4 5))
        c5 (model/add-event c4 (model/new-event :e5 5 6))
        c6 (model/add-event c5 (model/new-event :e6 6 7))
        c7 (model/add-event c6 (model/new-event :e7 7 8))
        c8 (model/add-event c7 (model/new-event :e8 8 9))
        overflow (model/add-event c8 (model/new-event :e9 9 10))]
    (if (= 2 (model/events-count calendar))
      (if (validate/valid? calendar)
        (if (model/overlaps? briefing review)
          (if (validate/event-valid? invalid) 4
            (match-option
              (model/event-by-id calendar :weekly-briefing) event-option-type
              (none 5)
              (some found
                (if (= 100 (record-get event-type found :start))
                  (match-option
                    (model/event-by-id calendar :missing) event-option-type
                    (none
                      (let [replaced (model/add-event calendar
                                       (model/new-event :weekly-briefing 300 330))]
                        (if (= 2 (model/events-count replaced))
                          (match-option
                            (model/event-by-id replaced :weekly-briefing) event-option-type
                            (none 7)
                            (some updated
                              (if (= 300 (record-get event-type updated :start))
                                (if (validate/valid? overflow) 11 42)
                                8)))
                          9)))
                    (some unexpected 10))
                  6))))
          3)
        2)
      1)))
